# Supabase PostgreSQL connection string.
# CRITICAL: use port 5432 (direct connection), NOT 6543 (Supavisor pooler).
# SELECT ... FOR UPDATE row locks used by this app fail in pooler transaction mode.
DATABASE_URL=postgresql://postgres:[PASS]@db.[REF].supabase.co:5432/postgres

# Port the API server listens on. On Replit this is injected automatically.
PORT=8080

# Reserved for future use (session signing). Set to a long random string.
SESSION_SECRET=change-this-to-a-random-string

# The deployed frontend origin. Used for CORS allow-list and reset-password links.
FRONTEND_URL=https://your-app.vercel.app

# SMTP settings for the forgot-password reset email.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
